# =============================================================================
# DocStream — Environment Variables
# =============================================================================
# HOW TO USE:
#   1. Copy this file to .env in the project root:
#         cp .env.example .env
#   2. Replace each placeholder value with your actual key or setting.
#   3. Never commit your .env file to version control.
#      It is already excluded via .gitignore.
# =============================================================================


# -----------------------------------------------------------------------------
# GROQ API KEY (required)
# -----------------------------------------------------------------------------
# Used for Llama 3.3 70B inference — the main LLM powering all Q&A responses.
#
# How to get one:
#   1. Go to https://console.groq.com
#   2. Sign up for a free account
#   3. Navigate to API Keys and create a new key
#   4. Copy and paste it below
#
GROQ_API_KEY=your_groq_api_key_here


# -----------------------------------------------------------------------------
# OPENAI API KEY (required for image captioning, optional otherwise)
# -----------------------------------------------------------------------------
# Used by GPT-4o Vision to generate educational captions for diagrams
# extracted from PDF documents.
#
# This key is only needed if you want to use the multimodal image feature.
# If you do not set this key:
#   - The image captioning toggle in the Upload tab will be disabled
#   - Text-based Q&A will still work normally
#
# How to get one:
#   1. Go to https://platform.openai.com/account/api-keys
#   2. Sign in or create an account
#   3. Click "Create new secret key"
#   4. Add billing credits at https://platform.openai.com/settings/organization/billing
#   5. Copy and paste the key below
#
# Approximate cost: $0.01 per image captioned
#
OPENAI_API_KEY=your_openai_api_key_here


# -----------------------------------------------------------------------------
# DEVICE (optional — defaults to cpu)
# -----------------------------------------------------------------------------
# Controls which hardware HuggingFace sentence-transformers runs on
# for generating text embeddings during ingestion and retrieval.
#
# Options:
#   cpu   — Works on any machine, no GPU required (default)
#   cuda  — Use if you have an NVIDIA GPU; significantly faster ingestion
#   mps   — Use if you are on Apple Silicon (M1/M2/M3 Mac)
#
DEVICE=cpu
